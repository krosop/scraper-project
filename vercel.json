{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/videos/(.*)", "dest": "/videos/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
