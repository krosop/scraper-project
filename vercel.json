{
  "version": 2,
  "framework": "vite",
  "outputDirectory": "dist/public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "src": "/scrape-data.json", "dest": "/scrape-data.json" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "server/**",
        "db/**",
        "drizzle.config.ts"
      ]
    }
  }
}